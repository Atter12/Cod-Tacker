NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_ALLOWED_EMAILS=
ENCRYPTION_KEY=
INTERNAL_JOB_SECRET=
CRON_SECRET=
WEBHOOK_GLOBAL_SECRET=
NEXT_PUBLIC_DEFAULT_LOCALE=es-PE
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Lima

# Integrations (server-only). Development defaults to mock when unset.
# Production must set INTEGRATION_MODE explicitly when resolving providers.
INTEGRATION_MODE=mock
MOCK_INTEGRATIONS_ENABLED=true

# Shopify (server-only — never NEXT_PUBLIC_*)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_REDIRECT_URI=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_SCOPES=read_orders,read_customers,read_products,read_fulfillments,read_locations,write_script_tags
# Live Shopify webhook callback is {SHOPIFY_APP_URL}/api/integrations/shopify/webhooks
# Attribution ScriptTag src is {SHOPIFY_APP_URL}/shopify/codtracked-attribution.js (must be publicly reachable)
# Set INTEGRATION_MODE=live + ENCRYPTION_KEY for OAuth token storage and live sync.
# Required to encrypt per-store access tokens (32-byte hex, base64, or passphrase)
ENCRYPTION_KEY=
# Job worker CLI guard (scripts/process-jobs.ts). Cron uses CRON_SECRET / INTERNAL_JOB_SECRET instead.
ALLOW_JOB_WORKER=false
# Optional Storage bucket for settlement CSV path metadata (Sprint 5). Unset = rows-only processing.
SETTLEMENT_CSV_BUCKET=
# Demo seed (CLI only — never required for normal app boot)
ALLOW_DEMO_SEED=false
DEMO_AGENCY_ID=
DEMO_STORE_ID=

# -----------------------------------------------------------------------------
# Meta Conversions API (S10 — Purchase on cash_collected)
# DEBT / Vercel: set these on Preview + Production (server-only). Do not invent
# values. Without both required vars, conversion_events.status = failed with
# last_error_message = missing_meta_capi_credentials (...).
#
# Vercel → Project → Settings → Environment Variables:
#   META_PIXEL_ID            = Pixel ID from Meta Events Manager
#   META_CAPI_ACCESS_TOKEN   = System User / CAPI access token for that Pixel
#   META_TEST_EVENT_CODE     = optional; Events Manager "Test events" code
#
# Alternative (per-store): integrations.settings for provider=meta with
#   pixel_id + capi_access_token (takes precedence over env).
# -----------------------------------------------------------------------------
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# -----------------------------------------------------------------------------
# Enviame live (S11 — webhook → job → normalize shipment)
# DEBT / Vercel: set on Preview + Production (server-only). Do not invent values.
#
# Webhook URL to register in Enviame:
#   {NEXT_PUBLIC_APP_URL}/api/integrations/enviame/webhooks
# Custom header in Enviame webhook config:
#   x-enviame-webhook-secret: <same as ENVIAME_WEBHOOK_SECRET>
#
# Optional: x-codtracked-store-id header or ENVIAME_DEFAULT_STORE_ID to pin tenant.
# Tracking (adapter health / getTracking):
#   GET {ENVIAME_API_BASE_URL}/api/s2/v2/deliveries/{identifier}/tracking
#   header api-key: ENVIAME_API_KEY
# Docs: https://docs.enviame.io/docs/webhooks/ · https://docs.enviame.io/docs/v2
# -----------------------------------------------------------------------------
ENVIAME_API_KEY=
ENVIAME_WEBHOOK_SECRET=
ENVIAME_API_BASE_URL=https://api.enviame.io
ENVIAME_COMPANY_ID=
ENVIAME_DEFAULT_STORE_ID=
